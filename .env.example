# =============================================================================
# Supabase（Project ID 拼 URL：https://[project-id].supabase.co）
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# 仅服务端使用，切勿暴露到客户端
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# =============================================================================
# 数据库（Supabase → Database → Connection string）
# =============================================================================
DATABASE_URL="postgresql://postgres.[project-id]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-id]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# =============================================================================
# DeepSeek（https://platform.deepseek.com/api_keys）
# =============================================================================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# =============================================================================
# GitHub 趋势分析（可选，提高 API 限额）
# https://github.com/settings/tokens
# =============================================================================
GITHUB_TOKEN=

# =============================================================================
# 学习视频联网搜索（https://tavily.com）
# 本地写在 .env；部署到 Vercel 等须在平台 Environment Variables 里单独添加同名变量
# =============================================================================
TAVILY_API_KEY=your-tavily-api-key

# =============================================================================
# Auth RSA 密码加密（首次运行: npx tsx scripts/generate-auth-keys.ts）
# =============================================================================
NEXT_PUBLIC_AUTH_RSA_PUBLIC_KEY=
AUTH_RSA_PRIVATE_KEY=

# =============================================================================
# 数据库种子（npm run db:seed）
# 使用 DeepSeek 按广东省小学课程标准生成语数英知识点，结果缓存到 prisma/data/
# =============================================================================
SEED_REGION=广东
# SEED_FORCE_REGENERATE=1
# SEED_USE_CACHE=0
